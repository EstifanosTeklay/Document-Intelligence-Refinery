# Gemini API key (Gemini-2.0-Flash)
GOOGLE_GEMINI_API_KEY=AIzaSyCGR-KEWUgwkx2k25_DjjKp_v87dWs6Q7s
GEMINI_MODEL=gemini-2.0-flash

# Model selection (budget-aware)
VISION_MODEL=google/gemini-flash-1.5        # cheap + fast
# VISION_MODEL=openai/gpt-4o-mini           # alternative

# Cost guardrails
MAX_COST_PER_DOCUMENT_USD=0.50              # hard cap per doc for Strategy C
MAX_VISION_PAGES_PER_DOC=50                 # max pages to send to VLM

# Extraction thresholds (can also be set in rubric/extraction_rules.yaml)
MIN_CHARS_PER_PAGE=100                      # below this = likely scanned
MAX_IMAGE_AREA_RATIO=0.50                   # above this = likely scanned

# Paths
REFINERY_DIR=.refinery
CORPUS_DIR=data/corpus
