{"chunk_id": "mcf_chunk_0006", "doc_id": "mcf", "chunk_index": 6, "content": "A: Yes. Staff may withdraw their ISP contributions (including employer and employee portions) upon contract termination and exiting the Foundation.", "chunk_type": "text", "page_refs": [1], "bounding_box": {"x0": 70.91999849999999, "y0": 598.7004813938122, "x1": 557.7062305888359, "y1": 618.87782235, "page": 1}, "content_hash": "84de28d280d51ec2c2602bcb5b46ef8340bcf5d23b22d02d55b72c05a0c5d7ba", "parent_section": "Q: Will the contributions we have made to the ISP be paid back to us?", "parent_section_page": 1, "token_count": 36, "relationships": [], "table_data": null, "figure_caption": null, "strategy_used": "B"}
